def mod_path(n):
    return os.path.join(PRACTICE_DIR, f"Mod{n}.py")


def is_not_done(n):
    path = mod_path(n)
    if not os.path.exists(path):
        return False
    with open(path) as f:
        for line in f:
            if "# I AM NOT DONE" in line:
                return True
    return False


def list_exercises():
    print(f"\n{BOLD}CHALLENGES:{RESET}\n")
    for i in range(1, 17):
        path = mod_path(i)
        if os.path.exists(path):
            done = not is_not_done(i)
            status = f"{GREEN}✔ Done{RESET}" if done else f"{RED}✘ Not Done{RESET}"
            print(f"  {i}. {status} — {MODULE_TITLES[i]}")
    print()


def find_next():
    for i in range(1, 17):
        if is_not_done(i):
            return i
    return None


def load_module(path):
    spec = importlib.util.spec_from_file_location("mod", path)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


_IS_TTY = sys.stdout.isatty()


def check(label, passed, hint=""):
    if not hasattr(check, 'total'):
        check.total = 0
        check.passed = 0
        check.failures = []
    check.total += 1
    if passed:
        check.passed += 1
    else:
        check.failures.append((label, hint))

    if _IS_TTY:
        failed = check.total - check.passed
        bar_len = 20
        filled = int(bar_len * check.passed / max(check.total, 1))
        bar = f"{GREEN}{'█' * filled}{RESET}{DIM}{'░' * (bar_len - filled)}{RESET}"
        if failed:
            status = f"{GREEN}{check.passed} passed{RESET}, {RED}{failed} failed{RESET}"
        else:
            status = f"{GREEN}{check.passed}/{check.total} passed{RESET}"
        print(f"\r  {bar}  {status}  ", end="", flush=True)
    else:
        if passed:
            print(f"  {GREEN}✔{RESET}  {label}")
        else:
            msg = f"  {RED}✘{RESET}  {label}"
            if hint:
                msg += f"\n     {DIM}hint: {hint}{RESET}"
            print(msg)
    return passed


def header(mod_num):
    print(f"\n{BOLD}{CYAN}{'─' * 50}{RESET}")
    print(f"{BOLD}{CYAN}  {MODULE_TITLES[mod_num]}{RESET}")
    print(f"{BOLD}{CYAN}{'─' * 50}{RESET}\n")


def summary(results, mod_num):
    passed = sum(results)
    total = len(results)
    bar_len = 30
    filled = int(bar_len * passed / total) if total else 0
    bar = f"{GREEN}{'█' * filled}{RESET}{DIM}{'░' * (bar_len - filled)}{RESET}"
    print(f"\n{BOLD}{CYAN}{'─' * 50}{RESET}")
    print(f"  {bar}  {BOLD}{passed}/{total}{RESET} passed")
    if passed == total:
        print(f"\n  {GREEN}{BOLD}ALL CHECKS PASSED! HIGH SCORE! DING DING DING!{RESET}")
        if is_not_done(mod_num):
            print(f"  {YELLOW}Remove '# I AM NOT DONE' from Practice/Mod{mod_num}.py{RESET}")
            print(f"  {YELLOW}to mark the exercise as complete.{RESET}")
    else:
        print(f"\n  {YELLOW}Keep going — fix the {RED}✘{RESET}{YELLOW} items above.{RESET}")
    print(f"{BOLD}{CYAN}{'─' * 50}{RESET}\n")
    return passed == total


def check_syntax(path):
    with open(path) as f:
        source = f.read()
    try:
        ast.parse(source)
        return None
    except SyntaxError as e:
        return e


def run_mod(n):
    path = mod_path(n)
    if not os.path.exists(path):
        print(f"\n{RED}Could not find {path}{RESET}")
        return False

    syntax_error = check_syntax(path)
    if syntax_error:
        print(f"\n{RED}{BOLD}Syntax Error{RESET}")
        print(f"  {path}:{syntax_error.lineno}:{syntax_error.offset}")
        print(f"\n  {RED}{syntax_error.msg}{RESET}")
        if syntax_error.text:
            print(f"\n  {DIM}{syntax_error.text.rstrip()}{RESET}")
            if syntax_error.offset:
                print(f"  {' ' * (syntax_error.offset - 1)}{RED}^{RESET}")
        print(f"\n  {YELLOW}Fix the syntax error and save again.{RESET}\n")
        return False

    header(n)

    try:
        mod = load_module(path)
    except Exception:
        print(f"{RED}Error loading Mod{n}.py:{RESET}\n")
        traceback.print_exc()
        print(f"\n{YELLOW}Fix the error above and run again.{RESET}\n")
        return False

    check.total = 0
    check.passed = 0
    check.failures = []

    results = TEST_MAP[n](mod)

    if _IS_TTY:
        print("\r" + " " * 80 + "\r", end="")
        if check.failures:
            for label, hint in check.failures:
                msg = f"  {RED}✘{RESET}  {label}"
                if hint:
                    msg += f"\n     {DIM}hint: {hint}{RESET}"
                print(msg)

    return summary(results, n)


